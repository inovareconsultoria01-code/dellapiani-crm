# Porta do backend
PORT=3000

# URL da Evolution API
# Exemplo local: http://localhost:8080
EVOLUTION_API_URL=http://localhost:8080

# API Key configurada na Evolution API
EVOLUTION_API_KEY=SUA_API_KEY_AQUI

# Tempo entre mensagens no disparo em milissegundos
BLAST_DELAY_MS=3500

# Permitir frontend
CORS_ORIGIN=*
